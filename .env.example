## Frontend -> Auth backend base URL (optional).
## If empty, frontend will call same-origin paths like /auth/me.
VITE_AUTH_BASE_URL=http://127.0.0.1:6000

## Backend (Flask) settings
FLASK_SECRET_KEY=change-me
AUTH_DB_PATH=/home/hoho/vite-project/auth.sqlite3

## One-time super admin seed (backend reads these at startup).
## If you set these and the user doesn't exist, it will be created as admin.
SUPER_ADMIN_USER=admin
SUPER_ADMIN_PASS=change-me

## LLM routing for Dseek.py /stream
## Default (if Azure vars below are NOT set): OpenAI-compatible vLLM at LLM_BASE_URL
LLM_BASE_URL=http://100.100.102.102:8000
LLM_MODEL=glm-4.7-flash

## Optional: Azure SDK path (only used if ALL three are set)
# AZURE_INFERENCE_SDK_ENDPOINT=https://.../models
# AZURE_INFERENCE_SDK_KEY=...
# DEPLOYMENT_NAME=DeepSeek-R1

